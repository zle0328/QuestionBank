{
  "name": "question-bank-api-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "import:local": "node scripts/import-local.mjs",
